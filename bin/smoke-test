#!/usr/bin/env bash
# smoke-test — exercise the installed environment to confirm a build is healthy.
#
# Stronger than `devtools check` (which only checks that a binary file exists):
# this RUNS each manifest tool's detect command, then runs a few functional
# cross-tool checks (compile + run C, create a uv venv, run TypeScript via tsx,
# exercise utility workflows, docker run hello-world). Core-tool failures make
# the script exit non-zero so it can gate a fresh-machine provision or CI;
# optional-tool failures are warnings.
#
# Not -e: we want to run every check and tally, not abort on the first failure.
set -uo pipefail

SCRIPT="$(readlink -f "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$(dirname "$SCRIPT")/.." && pwd)"
CATALOG="$REPO_ROOT/manifest/catalog.json"
LOCAL_MANIFEST="${DEVENV_MANIFEST:-$HOME/tools/manifest/tools.json}"
if [ -f "$LOCAL_MANIFEST" ]; then
    MANIFEST="$LOCAL_MANIFEST"
else
    MANIFEST="$CATALOG"
fi
export PATH="$HOME/.local/bin:$HOME/tools/bin:$HOME/.cargo/bin:$PATH"

_c()  { if [ -t 1 ]; then printf '\033[%sm' "$1"; fi; }
PASS=0; FAIL=0; WARN=0
ok()   { printf '%s✓%s %s\n' "$(_c 32)" "$(_c 0)" "$*"; PASS=$((PASS+1)); }
fail() { printf '%s✗%s %s\n' "$(_c 31)" "$(_c 0)" "$*"; FAIL=$((FAIL+1)); }
warn() { printf '%s⚠%s %s\n' "$(_c 33)" "$(_c 0)" "$*"; WARN=$((WARN+1)); }
hdr()  { printf '\n%s== %s ==%s\n' "$(_c 1)" "$*" "$(_c 0)"; }

[ -f "$MANIFEST" ] || { echo "inventory/catalog not found: $MANIFEST"; exit 1; }

# ── Phase 1: run every manifest tool's detect command ─────────────────────────
hdr "manifest tools (running detect commands)"
while IFS=$'\t' read -r name detect status; do
    if timeout 60 bash -c "$detect" >/dev/null 2>&1; then
        ok "$name"
    elif [ "$status" = "optional" ]; then
        warn "$name — detect failed (optional)"
    else
        fail "$name — detect failed: $detect"
    fi
done < <(jq -r '.[] | "\(.name)\t\(.detect)\t\(.status)"' "$MANIFEST")

# ── Phase 2: functional cross-tool checks ─────────────────────────────────────
hdr "functional checks"
tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT

# C toolchain: compile and run.
if command -v gcc >/dev/null 2>&1; then
    printf '#include <stdio.h>\nint main(void){puts("ok");return 0;}\n' > "$tmp/h.c"
    if gcc "$tmp/h.c" -o "$tmp/h" 2>/dev/null && [ "$("$tmp/h" 2>/dev/null)" = "ok" ]; then
        ok "gcc compiles and runs a C program"
    else
        fail "gcc could not compile/run a trivial C program"
    fi
else
    warn "gcc not present — skipping C check"
fi

# uv: create a project virtual environment.
if command -v uv >/dev/null 2>&1; then
    if uv venv "$tmp/venv" >/dev/null 2>&1 && [ -x "$tmp/venv/bin/python" ]; then
        ok "uv creates a project venv"
    else
        fail "uv could not create a venv"
    fi
else
    warn "uv not present — skipping venv check"
fi

# tsx: run a TypeScript one-liner.
if command -v tsx >/dev/null 2>&1; then
    echo 'const m: string = "ok"; console.log(m);' > "$tmp/s.ts"
    if [ "$(tsx "$tmp/s.ts" 2>/dev/null)" = "ok" ]; then
        ok "tsx runs TypeScript directly"
    else
        fail "tsx could not run a TypeScript file"
    fi
else
    warn "tsx not present — skipping TypeScript check"
fi

# Docker: run hello-world if the daemon is reachable (needs daemon + group).
if command -v docker >/dev/null 2>&1; then
    if docker info >/dev/null 2>&1; then
        if docker run --rm hello-world >/dev/null 2>&1; then
            ok "docker runs a container (hello-world)"
        else
            fail "docker daemon reachable but 'docker run' failed"
        fi
    else
        warn "docker present but daemon unreachable — re-login for the docker group, or start dockerd (not a build failure)"
    fi
else
    warn "docker not present — skipping container check"
fi

# ncdu + duf: scan/report a temporary directory without launching an interactive UI.
if command -v ncdu >/dev/null 2>&1 && command -v duf >/dev/null 2>&1; then
    mkdir -p "$tmp/disk"
    printf 'ok\n' > "$tmp/disk/file.txt"
    if ncdu -o "$tmp/ncdu-export.json" "$tmp/disk" >/dev/null 2>&1 \
        && duf --json "$tmp/disk" >/dev/null 2>&1; then
        ok "ncdu and duf inspect disk usage non-interactively"
    else
        fail "ncdu/duf disk usage check failed"
    fi
else
    warn "ncdu or duf not present — skipping disk-usage check"
fi

# yt-dlp + aria2: verify downloader CLIs are ready. Network downloads are left
# out of smoke-test so the gate stays deterministic offline.
if command -v yt-dlp >/dev/null 2>&1 && command -v aria2c >/dev/null 2>&1; then
    if yt-dlp --version >/dev/null 2>&1 && aria2c --version >/dev/null 2>&1; then
        ok "yt-dlp and aria2 downloader CLIs respond"
    else
        fail "yt-dlp/aria2 downloader check failed"
    fi
else
    warn "yt-dlp or aria2 not present — skipping downloader check"
fi

# just: run a tiny local recipe.
if command -v just >/dev/null 2>&1; then
    mkdir -p "$tmp/just"
    printf 'default:\n    @echo ok\n' > "$tmp/just/justfile"
    if [ "$(just --justfile "$tmp/just/justfile" 2>/dev/null)" = "ok" ]; then
        ok "just runs a local recipe"
    else
        fail "just could not run a local recipe"
    fi
else
    warn "just not present — skipping command-runner check"
fi

# age + sops: create an age key, encrypt/decrypt a small YAML document.
if command -v age >/dev/null 2>&1 && command -v age-keygen >/dev/null 2>&1; then
    age-keygen -o "$tmp/age.key" >/dev/null 2>&1
    age_pub="$(awk '/public key:/{print $NF; exit}' "$tmp/age.key")"
    if printf 'ok\n' | age -r "$age_pub" -o "$tmp/plain.txt.age" >/dev/null 2>&1 \
        && [ "$(age -d -i "$tmp/age.key" "$tmp/plain.txt.age" 2>/dev/null)" = "ok" ]; then
        ok "age encrypts and decrypts with a generated recipient"
    else
        fail "age could not round-trip encrypted data"
    fi

    if command -v sops >/dev/null 2>&1; then
        printf 'secret: ok\n' > "$tmp/plain.yaml"
        if SOPS_AGE_KEY_FILE="$tmp/age.key" sops --encrypt --age "$age_pub" "$tmp/plain.yaml" > "$tmp/encrypted.yaml" 2>/dev/null \
            && SOPS_AGE_KEY_FILE="$tmp/age.key" sops --decrypt "$tmp/encrypted.yaml" 2>/dev/null | grep -qx 'secret: ok'; then
            ok "sops encrypts and decrypts YAML with age"
        else
            fail "sops could not round-trip YAML with age"
        fi
    else
        warn "sops not present — skipping encrypted-config check"
    fi
else
    warn "age not present — skipping age/sops encryption checks"
fi

# rclone: copy between local directories through rclone's local backend.
if command -v rclone >/dev/null 2>&1; then
    mkdir -p "$tmp/rclone-src" "$tmp/rclone-dst"
    printf 'ok\n' > "$tmp/rclone-src/file.txt"
    if rclone copy "$tmp/rclone-src" "$tmp/rclone-dst" >/dev/null 2>&1 \
        && [ "$(cat "$tmp/rclone-dst/file.txt" 2>/dev/null)" = "ok" ]; then
        ok "rclone copies files with the local backend"
    else
        fail "rclone could not copy with the local backend"
    fi
else
    warn "rclone not present — skipping sync check"
fi

# direnv: verify the stdlib is available without allowing a project .envrc.
if command -v direnv >/dev/null 2>&1; then
    if direnv stdlib 2>/dev/null | grep -q 'layout_python'; then
        ok "direnv exposes its shell stdlib"
    else
        fail "direnv stdlib check failed"
    fi
else
    warn "direnv not present — skipping env-loader check"
fi

# tesseract: verify binary starts and English language data is present.
if command -v tesseract >/dev/null 2>&1; then
    if tesseract --list-langs 2>/dev/null | grep -q '^eng$'; then
        ok "tesseract has English language data"
    else
        fail "tesseract: English language data missing (apt install tesseract-ocr-eng)"
    fi
else
    warn "tesseract not present — skipping OCR check"
fi

# ghostscript: interpret a minimal PostScript program.
if command -v gs >/dev/null 2>&1; then
    if printf '%%PS\n(ok) =\n' | gs -q -dNOPAUSE -dBATCH -sDEVICE=nullpage - >/dev/null 2>&1; then
        ok "ghostscript interprets PostScript"
    else
        fail "ghostscript could not interpret a minimal PostScript program"
    fi
else
    warn "ghostscript not present — skipping PS interpreter check"
fi

# qpdf + pdfinfo: create a minimal PDF with qpdf, then inspect it with pdfinfo.
if command -v qpdf >/dev/null 2>&1 && command -v pdfinfo >/dev/null 2>&1; then
    if qpdf --empty "$tmp/smoke.pdf" >/dev/null 2>&1 \
        && pdfinfo "$tmp/smoke.pdf" >/dev/null 2>&1; then
        ok "qpdf creates a valid PDF; pdfinfo reads it"
    else
        fail "qpdf/pdfinfo PDF utilities check failed"
    fi
else
    warn "qpdf or pdfinfo not present — skipping PDF utilities check"
fi

# libreoffice headless: confirm soffice starts without a display.
if command -v soffice >/dev/null 2>&1; then
    if soffice --headless --version >/dev/null 2>&1; then
        ok "libreoffice headless is available"
    else
        fail "soffice --headless --version failed"
    fi
else
    warn "libreoffice not present — skipping office headless check"
fi

# ipython office + data libs: all five must be importable.
if command -v ipython >/dev/null 2>&1; then
    missing_libs=()
    for lib in docx pptx openpyxl pandas numpy; do
        ipython -c "import $lib" >/dev/null 2>&1 || missing_libs+=("$lib")
    done
    if [ ${#missing_libs[@]} -eq 0 ]; then
        ok "ipython: docx, pptx, openpyxl, pandas, numpy all importable"
    else
        fail "ipython: missing injected libs: ${missing_libs[*]}"
    fi
else
    warn "ipython not present — skipping office/data lib check"
fi

# ── Summary ───────────────────────────────────────────────────────────────────
hdr "summary"
printf '%s%d passed%s, %s%d warnings%s, %s%d failed%s\n' \
    "$(_c 32)" "$PASS" "$(_c 0)" "$(_c 33)" "$WARN" "$(_c 0)" "$(_c 31)" "$FAIL" "$(_c 0)"
[ "$FAIL" -eq 0 ] || { echo "SMOKE TEST FAILED"; exit 1; }
echo "smoke test passed"
